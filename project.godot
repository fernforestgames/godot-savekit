; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SaveKit Demo"
run/main_scene="res://demo/demo.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

SaveManager="*uid://ck4ih2layufdo"

[debug]

gdscript/warnings/directory_rules={
"res://addons": 0,
"res://addons/savekit": 1
}
gdscript/warnings/untyped_declaration=1
gdscript/warnings/unsafe_property_access=2
gdscript/warnings/unsafe_method_access=2
gdscript/warnings/unsafe_call_argument=1
gdscript/warnings/missing_await=1

[display]

window/subwindows/embed_subwindows=false

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg", "res://addons/savekit/plugin.cfg")

[global_group]

saveable=""

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
